const promptBox = document.querySelector("#promptBox");
const messages = document.querySelector("#messages");
const toast = document.querySelector("#toast");
const phraseRow = document.querySelector("#phraseRow");

// Configuration sets for dynamic phrases matching the selected chat history
const phraseSets = {
    "1440p gaming": ["Ask for a quieter version", "Show cheaper GPU alternatives", "Explain motherboard tradeoffs"],
    "video editing": ["Prioritize render speed", "Add scratch disk options", "Make it quieter"],
    "upgrade": ["Check PSU requirements", "Rank upgrades by impact", "Keep my current case"]
};

// Custom layout toast alert notifier
function showToast(text) {
    toast.textContent = text;
    toast.classList.add("is-visible");
    window.setTimeout(() => toast.classList.remove("is-visible"), 1800);
}

// Generate chat bubbles dynamically
function addMessage(kind, text) {
    const article = document.createElement("article");
    article.className = `message ${kind}`;
    const avatar = document.createElement("div");
    avatar.className = "avatar";
    avatar.textContent = kind === "user" ? "U" : "R";
    const bubble = document.createElement("div");
    bubble.className = "bubble";
    bubble.textContent = text;
    article.append(avatar, bubble);
    messages.append(article);
    messages.scrollTop = messages.scrollHeight;
}

// Interactive Suggested Prompt Chips
document.querySelectorAll(".chip").forEach((chip) => {
    chip.addEventListener("click", () => {
        document.querySelectorAll(".chip").forEach((item) => item.classList.remove("is-selected"));
        chip.classList.add("is-selected");
        promptBox.value = chip.dataset.prompt;
        promptBox.focus();
    });
});

// Appends quick phrase helpers to current text block
phraseRow.addEventListener("click", (event) => {
    const phrase = event.target.closest(".phrase");
    if (!phrase) return;
    promptBox.value = `${promptBox.value.trim()} ${phrase.dataset.phrase}.`.trim();
    promptBox.focus();
});

// Event Handler: Dispatching network context payload to Backend Web server
document.querySelector("#sendBtn").addEventListener("click", async () => {
    const text = promptBox.value.trim();
    if (!text) {
        showToast("Add a budget or use case first");
        promptBox.focus();
        return;
    }
    
    // 1. Display user's message
    addMessage("user", text);
    promptBox.value = "";
    
    // 2. Add dynamic loading animation state
    const loadingId = "loading-" + Date.now();
    addMessage("assistant", "Ramsey is thinking...");
    const loadingMessage = messages.lastElementChild.querySelector(".bubble");
    loadingMessage.id = loadingId;

    // Inject the HTML markup framework for the animated dots
    loadingMessage.innerHTML = `Ramsey thinking<span class="typing-indicator"><span>.</span><span>.</span><span>.</span></span>`;

    try {
        // Pointing to your live production server address on port 8080
        const response = await fetch("https://your-project.up.railway.app/api/chat", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ message: text })
        });
        
        const data = await response.json();
        console.log("Ramsey's raw data:", data);
        
        // 3. Update the interface layouts with clean data parse mapping
        const bubbleToUpdate = document.getElementById(loadingId);
        
        if (data.response) {
            bubbleToUpdate.innerHTML = marked.parse(data.response);
            
            if (data.parts) {
                updateBuildList(data.parts, data.prices);
            }
            if (data.upgrades) {
                updateUpgradePanel(data.upgrades);
            }
            if (data.benchmark) {
                updateBenchmarkPanel(data.benchmark);
            }
        } else {
            bubbleToUpdate.textContent = "Oops, hit an error: " + data.error;
        }
    } catch (error) {
        document.getElementById(loadingId).textContent = "Cannot connect to the AI server. Is the Railway application online?";
        console.error(error);
    }
});

// Sidebar History Card selections
document.querySelectorAll(".history-card").forEach((card) => {
    card.addEventListener("click", () => {
        document.querySelectorAll(".history-card").forEach((item) => item.classList.remove("is-active"));
        card.classList.add("is-active");
        const phrases = phraseSets[card.dataset.chat] || phraseSets["1440p gaming"];
        phraseRow.innerHTML = phrases.map((phrase) => `<button class="phrase" data-phrase="${phrase}">${phrase}</button>`).join("");
        showToast(`${card.querySelector("strong").textContent} loaded`);
    });
});

// Nav Panel Tabs (Parts / Upgrades / Benchmarks) switching logic
document.querySelectorAll(".tab").forEach((tab) => {
    tab.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach((item) => {
            item.classList.remove("is-active");
            item.setAttribute("aria-selected", "false");
        });
        document.querySelectorAll(".tab-page").forEach((page) => page.classList.remove("is-active"));
        tab.classList.add("is-active");
        tab.setAttribute("aria-selected", "true");
        document.querySelector(`#${tab.dataset.tab}`).classList.add("is-active");
    });
});

// System Clipboard configuration logic
document.querySelector("#copyBtn").addEventListener("click", async () => {
    const parts = Array.from(document.querySelectorAll("#partsList .spec-row"))
        .map((row) => row.textContent.trim().replace(/\s+/g, ": "))
        .join("\n");
    try {
        await navigator.clipboard.writeText(parts);
        showToast("Parts list copied");
    } catch {
        showToast("Copy unavailable in preview");
    }
});

// Data Parser Function: Maps parts and prices to the right table element rows
function updateBuildList(parts, prices) {
    const rows = document.querySelectorAll("#partsList .spec-row");
    
    rows.forEach(row => {
        const label = row.querySelector(".muted").textContent.trim();
        
        if (parts[label] && parts[label] !== "null") {
            const valueSpan = row.querySelector(".value");
            valueSpan.textContent = parts[label];
            valueSpan.style.color = "var(--success)";
            setTimeout(() => valueSpan.style.color = "", 1000);

            // Add dynamic pricing tags under the designated component
            const priceData = prices?.[label];
            let priceEl = row.querySelector(".price-tag");
            if (!priceEl) {
                priceEl = document.createElement("span");
                priceEl.className = "price-tag";
                row.appendChild(priceEl);
            }
            if (priceData && priceData.price) {
                priceEl.textContent = `${priceData.price} · ${priceData.source}`;
            }
        }
    });

    // Sum Total Calculation Display card
    const priceData = prices?.total_estimate;
    if (priceData) {
        let totalEl = document.getElementById("totalEstimate");
        if (!totalEl) {
            totalEl = document.createElement("div");
            totalEl.id = "totalEstimate";
            totalEl.className = "notice";
            document.getElementById("partsList").appendChild(totalEl);
        }
        totalEl.innerHTML = `<strong>Total Estimate</strong><p class="muted">${priceData}</p>`;
    }
}

// Data Parser Function: Populates the Keep/Replace/Delay upgrade tracks
function updateUpgradePanel(upgrades) {
    const lists = {
        keepList:    upgrades.keep,
        replaceList: upgrades.replace_first,
        delayList:   upgrades.delay
    };

    for (const [id, items] of Object.entries(lists)) {
        const el = document.getElementById(id);
        if (!el || !Array.isArray(items) || items.length === 0) continue;
        el.innerHTML = items.map(item => `<li>${item}</li>`).join("");
    }
}

// Data Parser Function: Renders benchmark scoring layouts and animations
function updateBenchmarkPanel(benchmark) {
    const sections = [
        { key: 'gaming',        barId: 'bench-gaming-bar',  scoreId: 'bench-gaming-score',  descId: 'bench-gaming-desc' },
        { key: 'work',          barId: 'bench-work-bar',    scoreId: 'bench-work-score',    descId: 'bench-work-desc' },
        { key: 'upgradability', barId: 'bench-upgrade-bar', scoreId: 'bench-upgrade-score', descId: 'bench-upgrade-desc' },
    ];

    const scoreClass = (score) => {
        if (score >= 75) return 'score-good';
        if (score >= 55) return 'score-warn';
        return 'score-bad';
    };

    sections.forEach(({ key, barId, scoreId, descId }) => {
        const data = benchmark[key];
        if (!data) return;

        // Animate percentage tracker lines
        const bar = document.getElementById(barId);
        if (bar) {
            bar.style.setProperty('--bar-value', '0%');
            requestAnimationFrame(() => {
                setTimeout(() => bar.style.setProperty('--bar-value', `${data.score}%`), 50);
            });
        }

        // Apply health color classes to numeric benchmarks
        const scoreEl = document.getElementById(scoreId);
        if (scoreEl) {
            scoreEl.textContent = data.label || `${data.score}%`;
            scoreEl.className = `score ${scoreClass(data.score)}`;
        }

        const descEl = document.getElementById(descId);
        if (descEl && data.description) descEl.textContent = data.description;
    });

    // Gaming conditions list (Runs Well vs Struggles)
    const gamingData = benchmark.gaming;
    if (gamingData) {
        const section = document.getElementById('bench-games-section');
        const goodList = document.getElementById('bench-games-good');
        const badList  = document.getElementById('bench-games-bad');

        if (Array.isArray(gamingData.games_good) && gamingData.games_good.length > 0) {
            goodList.innerHTML = gamingData.games_good.map(g => `<li>${g}</li>`).join('');
            section.style.display = 'block';
        }
        if (Array.isArray(gamingData.games_bad) && gamingData.games_bad.length > 0) {
            badList.innerHTML = gamingData.games_bad.map(g => `<li>${g}</li>`).join('');
            section.style.display = 'block';
        }
    }

    // Auto focus dashboard viewpoint to insights tab
    const benchTab = document.querySelector('[data-tab=\"bench\"]');
    if (benchTab) benchTab.click();
}